# ── Chainalysis ──────────────────────────────────────────────────────────────
# Free API key from https://go.chainalysis.com/sanctions-screening-api.html
CHAINALYSIS_API_KEY=

# ── Turnkey (parent org) ──────────────────────────────────────────────────────
# From https://app.turnkey.com/dashboard/api-keys
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORG_ID=

# Public — safe to expose in the browser
NEXT_PUBLIC_TURNKEY_ORG_ID=

# From https://app.turnkey.com/dashboard/auth → Auth Proxy tab
# Enable Auth Proxy, configure Allowed Origins, then paste the Config ID here
NEXT_PUBLIC_AUTH_PROXY_CONFIG_ID=

# ── TVC App ───────────────────────────────────────────────────────────────────
# Set after deploying the TVC app (Step 5 of walkthrough)
TVC_APP_URL=https://app-<your-app-uuid>.turnkey.cloud
TVC_APP_ID=
